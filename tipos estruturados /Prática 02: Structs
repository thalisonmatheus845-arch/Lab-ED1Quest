#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_TURMAS 10
#define MAX_VAGAS 3

// ===== STRUCTS =====

typedef struct aluno {
    int mat;
    char nome[81];
    float notas[3];
    float media;
} Aluno;

typedef struct turma {
    char id;
    int vagas;
    Aluno* alunos[MAX_VAGAS];
} Turma;

// ===== FUNÇÕES =====

// a)
Turma* cria_turma(char id) {
    Turma* t = (Turma*) malloc(sizeof(Turma));

    if (t == NULL) {
        printf("Erro de memoria!\n");
        return NULL;
    }

    t->id = id;
    t->vagas = MAX_VAGAS;

    for (int i = 0; i < MAX_VAGAS; i++) {
        t->alunos[i] = NULL;
    }

    return t;
}

// b)
void matricula_aluno(Turma* turma, int mat, char* nome) {
    if (turma == NULL) return;

    if (turma->vagas == 0) {
        printf("Turma cheia!\n");
        return;
    }

    for (int i = 0; i < MAX_VAGAS; i++) {
        if (turma->alunos[i] == NULL) {
            Aluno* a = (Aluno*) malloc(sizeof(Aluno));

            a->mat = mat;
            strcpy(a->nome, nome);

            for (int j = 0; j < 3; j++) {
                a->notas[j] = 0;
            }
            a->media = 0;

            turma->alunos[i] = a;
            turma->vagas--;

            printf("Aluno matriculado com sucesso!\n");
            return;
        }
    }
}

// c)
void lanca_notas(Turma* turma) {
    if (turma == NULL) return;

    for (int i = 0; i < MAX_VAGAS; i++) {
        if (turma->alunos[i] != NULL) {
            Aluno* a = turma->alunos[i];

            printf("\nMatricula: %d Aluno: %s\n", a->mat, a->nome);

            float soma = 0;
            for (int j = 0; j < 3; j++) {
                printf("Digite a nota %d: ", j + 1);
                scanf("%f", &a->notas[j]);
                soma += a->notas[j];
            }

            a->media = soma / 3;
        }
    }
}

// d)
void imprime_alunos(Turma* turma) {
    if (turma == NULL) return;

    for (int i = 0; i < MAX_VAGAS; i++) {
        if (turma->alunos[i] != NULL) {
            Aluno* a = turma->alunos[i];

            printf("\nMatricula: %d\n", a->mat);
            printf("Nome: %s\n", a->nome);
            printf("Media: %.2f\n", a->media);
        }
    }
}

// e)
void imprime_turmas(Turma** turmas, int n) {
    for (int i = 0; i < n; i++) {
        if (turmas[i] != NULL) {
            printf("Turma %c - %d vagas disponiveis\n",
                   turmas[i]->id,
                   turmas[i]->vagas);
        }
    }
}

// f)
Turma* procura_turma(Turma** turmas, int n, char id) {
    for (int i = 0; i < n; i++) {
        if (turmas[i] != NULL && turmas[i]->id == id) {
            return turmas[i];
        }
    }
    return NULL;
}

// ===== MAIN (MENU) =====

int main() {
    Turma* turmas[MAX_TURMAS] = {NULL};
    int total = 0;
    int opcao;

    printf("Bem-vindo ao Programa de Gerenciamento de Turmas!\n");

    do {
        printf("\nMENU:\n");
        printf("1 - Criar turma\n");
        printf("2 - Listar turmas\n");
        printf("3 - Matricular aluno\n");
        printf("4 - Lancar notas\n");
        printf("5 - Listar alunos\n");
        printf("6 - Sair\n");
        printf("Opcao: ");
        scanf("%d", &opcao);
        getchar();

        if (opcao == 1) {
            char id;
            printf("Digite o id da turma: ");
            scanf("%c", &id);
            getchar();

            if (total < MAX_TURMAS) {
                turmas[total] = cria_turma(id);
                printf("Turma %c criada com sucesso!\n", id);
                total++;
            } else {
                printf("Limite de turmas atingido!\n");
            }
        }

        else if (opcao == 2) {
            imprime_turmas(turmas, total);
        }

        else if (opcao == 3) {
            char id;
            int mat;
            char nome[81];

            printf("Digite o id da turma: ");
            scanf("%c", &id);
            getchar();

            Turma* t = procura_turma(turmas, total, id);

            if (t == NULL) {
                printf("Turma inexistente!\n");
            } else {
                printf("Matricula: ");
                scanf("%d", &mat);
                getchar();

                printf("Nome: ");
                fgets(nome, 81, stdin);
                nome[strcspn(nome, "\n")] = '\0';

                matricula_aluno(t, mat, nome);
            }
        }

        else if (opcao == 4) {
            char id;
            printf("Digite o id da turma: ");
            scanf("%c", &id);
            getchar();

            Turma* t = procura_turma(turmas, total, id);

            if (t == NULL) {
                printf("Turma inexistente!\n");
            } else {
                lanca_notas(t);
            }
        }

        else if (opcao == 5) {
            char id;
            printf("Digite o id da turma: ");
            scanf("%c", &id);
            getchar();

            Turma* t = procura_turma(turmas, total, id);

            if (t == NULL) {
                printf("Turma inexistente!\n");
            } else {
                imprime_alunos(t);
            }
        }

    } while (opcao != 6);

    printf("Obrigado por usar o programa!\n");

    return 0;
}
