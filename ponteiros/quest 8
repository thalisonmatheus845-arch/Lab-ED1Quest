#include <stdio.h>

int maiorElemento(int *v, int n) {
    int maior = *v;

    for (int i = 1; i < n; i++) {
        if (*(v + i) > maior) {
            maior = *(v + i);
        }
    }

    return maior;
}

int main() {
    int v[5] = {1,2,3,4,5};

    printf("Maior elemento: %d\n", maiorElemento(v, 5));

    return 0;
}
