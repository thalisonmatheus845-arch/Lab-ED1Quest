#include <stdio.h>

void inverter(int *v, int n) {
    int *inicio = v;
    int *fim = v + n - 1;
    int temp;

    while (inicio < fim) {
        temp = *inicio;
        *inicio = *fim;
        *fim = temp;

        inicio++;
        fim--;
    }
}

int main() {
    int v[5] = {1,2,3,4,5};

    inverter(v, 5);

    for (int i = 0; i < 5; i++) {
        printf("%d ", v[i]);
    }

    return 0;
}
