#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main() {
    int n;

    printf("Digite o numero de pessoas: ");
    scanf("%d", &n);
    getchar(); // limpar buffer

    char **nomes = (char **) malloc(n * sizeof(char *));
    int *idades = (int *) malloc(n * sizeof(int));

    if (nomes == NULL || idades == NULL) {
        printf("Erro de memoria\n");
        return 1;
    }

    for (int i = 0; i < n; i++) {
        nomes[i] = (char *) malloc(100 * sizeof(char));

        printf("Digite o nome completo da pessoa %d: ", i + 1);
        fgets(nomes[i], 100, stdin);

        // remover \n do fgets
        nomes[i][strcspn(nomes[i], "\n")] = '\0';

        printf("Digite a idade: ");
        scanf("%d", &idades[i]);
        getchar(); // limpar buffer
    }

    printf("\nNomes armazenados:\n");
    for (int i = 0; i < n; i++) {
        printf("%s\n", nomes[i]);
    }

    // liberar memória
    for (int i = 0; i < n; i++) {
        free(nomes[i]);
    }
    free(nomes);
    free(idades);

    return 0;
}
