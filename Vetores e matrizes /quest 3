#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int n;

    printf("Digite o tamanho da matriz (n x n): ");
    scanf("%d", &n);

    int **mat = (int **) malloc(n * sizeof(int *));
    for (int i = 0; i < n; i++) {
        mat[i] = (int *) malloc(n * sizeof(int));
    }

    srand(time(NULL));

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            mat[i][j] = rand() % 100 + 1;
        }
    }

    printf("\nMatriz gerada:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            printf("%d ", mat[i][j]);
        }
        printf("\n");
    }

    for (int i = 0; i < n; i++) {
        free(mat[i]);
    }
    free(mat);

    return 0;
}
